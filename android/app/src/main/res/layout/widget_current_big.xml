<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded variant of widget_current, used when the widget is 2+ rows
     tall: larger type plus feels-like, high/low, humidity, and wind. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sky_loading"
    android:gravity="start|center_vertical"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/glyph"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:includeFontPadding="false"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:textColor="#FFFFFFFF"
                android:textSize="46sp" />

            <TextView
                android:id="@+id/cond"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:textColor="#DEFFFFFF"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/loc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:shadowColor="#40000000"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:textColor="#99FFFFFF"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/metrics1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:shadowColor="#40000000"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:textColor="#DEFFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/metrics2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:shadowColor="#40000000"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:textColor="#B3FFFFFF"
        android:textSize="13sp" />
</LinearLayout>
