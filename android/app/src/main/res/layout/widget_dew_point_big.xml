<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded variant of widget_dew_point, used when the widget is 2+ rows
     tall: larger type plus the comfort blurb and gauge. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sky_loading"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.12"
        android:shadowColor="#40000000"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:text="@string/widget_caption_dew_point"
        android:textColor="#B3FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/dew_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:includeFontPadding="false"
            android:shadowColor="#40000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:textColor="#FFFFFFFF"
            android:textSize="50sp" />

        <TextView
            android:id="@+id/comfort_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="6dp"
            android:shadowColor="#66000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:textColor="#FFFFFFFF"
            android:textSize="21sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/feels"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:shadowColor="#40000000"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:textColor="#DEFFFFFF"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/blurb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:shadowColor="#40000000"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:textColor="#BFFFFFFF"
        android:textSize="13sp" />

    <ImageView
        android:id="@+id/gauge"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:layout_marginTop="8dp"
        android:importantForAccessibility="no"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_scale_dry"
            android:textColor="#8CFFFFFF"
            android:textSize="9sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/widget_scale_comfort"
            android:textColor="#8CFFFFFF"
            android:textSize="9sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/widget_scale_muggy"
            android:textColor="#8CFFFFFF"
            android:textSize="9sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="@string/widget_scale_severe"
            android:textColor="#8CFFFFFF"
            android:textSize="9sp" />
    </LinearLayout>
</LinearLayout>
