<?xml version="1.0" encoding="utf-8"?>
<!-- Large widget: current conditions, dew point comfort blurb + gauge, and
     the next 5 hours. Weighted spacers spread the sections over whatever
     height the widget is given. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sky_loading"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/loc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:shadowColor="#40000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#40000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:textColor="#80FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/glyph"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-light"
            android:includeFontPadding="false"
            android:shadowColor="#40000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:textColor="#FFFFFFFF"
            android:textSize="48sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/cond"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:textColor="#DEFFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/feels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/comfort_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:shadowColor="#66000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:textColor="#FFFFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dew_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#40000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:textColor="#E6FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/blurb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:shadowColor="#40000000"
        android:shadowDy="1"
        android:shadowRadius="3"
        android:textColor="#BFFFFFFF"
        android:textSize="12sp" />

    <ImageView
        android:id="@+id/gauge"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:layout_marginTop="6dp"
        android:importantForAccessibility="no"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_scale_dry"
            android:textColor="#8CFFFFFF"
            android:textSize="9sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/widget_scale_comfort"
            android:textColor="#8CFFFFFF"
            android:textSize="9sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/widget_scale_muggy"
            android:textColor="#8CFFFFFF"
            android:textSize="9sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="@string/widget_scale_severe"
            android:textColor="#8CFFFFFF"
            android:textSize="9sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/l0_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#BFFFFFFF"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/l0_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="2dp"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/l0_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/l1_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#BFFFFFFF"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/l1_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="2dp"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/l1_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/l2_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#BFFFFFFF"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/l2_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="2dp"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/l2_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/l3_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#BFFFFFFF"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/l3_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="2dp"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/l3_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/l4_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#BFFFFFFF"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/l4_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="2dp"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/l4_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:shadowColor="#40000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:includeFontPadding="false"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
