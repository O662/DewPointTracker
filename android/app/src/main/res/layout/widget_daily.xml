<?xml version="1.0" encoding="utf-8"?>
<!-- Wide widget: the next 5 days. Compact enough for a 1-row cell;
     the renderer hides trailing columns when the widget is narrow. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sky_loading"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/d0_col"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/d0_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#40000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:includeFontPadding="false"
            android:textColor="#BFFFFFFF"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/d0_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="2dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/d0_hi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:shadowColor="#40000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:includeFontPadding="false"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/d0_lo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#40000000"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:includeFontPadding="false"
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

